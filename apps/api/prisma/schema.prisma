generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum OrderStatus {
  REGISTERED
  IN_PROGRESS
  PAUSED
  CANCELED
  FINISHED
}

enum OrderQuantityMode {
  SINGLE
  SIZE_GRID
}

model Company {
  id               String            @id @default(uuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  measurementUnits MeasurementUnit[]
  variables        Variable[]
  sectors          Sector[]
  stages           Stage[]
  templates        Template[]
  sizes            ClothingSize[]
  customers        Customer[]
  products         Product[]
  orders           Order[]
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model MeasurementUnit {
  id        String   @id @default(uuid())
  companyId String
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  stages  Stage[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
}

model Variable {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  stages  Stage[]
  productDefaults ProductVariableDefault[]

  @@unique([companyId, name])
  @@index([companyId])
}

model ClothingSize {
  id        String   @id @default(uuid())
  companyId String
  name      String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  orderItemSizes OrderItemSize[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Customer {
  id            String   @id @default(uuid())
  companyId     String
  name          String
  cpf           String?
  cnpj          String?
  address       String?
  mobilePhone   String?
  landlinePhone String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  orders  Order[]

  @@unique([companyId, cpf])
  @@unique([companyId, cnpj])
  @@index([companyId])
}

model Product {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  costPrice   Decimal  @db.Decimal(12, 2)
  salePrice   Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  variableDefaults ProductVariableDefault[]
  orderItems OrderItem[]

  @@unique([companyId, name])
  @@index([companyId])
}

model ProductVariableDefault {
  id         String  @id @default(uuid())
  productId  String
  variableId String
  value      Decimal @db.Decimal(12, 2)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variable Variable @relation(fields: [variableId], references: [id])

  @@unique([productId, variableId])
  @@index([productId])
  @@index([variableId])
}

model Sector {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  stages  Stage[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Stage {
  id                 String   @id @default(uuid())
  companyId          String
  sectorId           String
  measurementUnitId  String
  variableId         String?
  name               String
  description        String?
  capacityPerWorkday Decimal  @db.Decimal(12, 2)
  position           Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id])
  sector          Sector          @relation(fields: [sectorId], references: [id])
  measurementUnit MeasurementUnit @relation(fields: [measurementUnitId], references: [id])
  variable        Variable?       @relation(fields: [variableId], references: [id])
  templateItems   TemplateItem[]
  orderItemStages OrderItemStage[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([sectorId])
  @@index([measurementUnitId])
  @@index([variableId])
}

model Template {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company        @relation(fields: [companyId], references: [id])
  items   TemplateItem[]
  orderItems OrderItem[]

  @@unique([companyId, name])
  @@index([companyId])
}

model TemplateItem {
  id         String  @id @default(uuid())
  templateId String
  stageId    String
  position   Int     @default(0)

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  stage    Stage    @relation(fields: [stageId], references: [id])

  @@index([templateId])
  @@index([stageId])
}

model Order {
  id           String      @id @default(uuid())
  companyId    String
  customerId   String
  orderNumber  String
  status       OrderStatus @default(REGISTERED)
  startDate    DateTime?   @db.Date
  deliveryDate DateTime?   @db.Date
  finalNotes   String?      @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company  Company     @relation(fields: [companyId], references: [id])
  customer Customer    @relation(fields: [customerId], references: [id])
  items    OrderItem[]

  @@unique([companyId, orderNumber])
  @@index([companyId])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id           String            @id @default(uuid())
  orderId      String
  productId    String
  templateId   String?
  position     Int               @default(0)
  quantityMode OrderQuantityMode @default(SINGLE)
  quantity     Decimal?          @db.Decimal(12, 2)
  notes        String?            @db.Text

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
  template Template? @relation(fields: [templateId], references: [id])
  sizes    OrderItemSize[]
  stages   OrderItemStage[]

  @@index([orderId])
  @@index([productId])
  @@index([templateId])
  @@map("order_items")
}

model OrderItemSize {
  id          String  @id @default(uuid())
  orderItemId String
  sizeId      String
  quantity    Decimal @db.Decimal(12, 2)

  orderItem OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  size      ClothingSize @relation(fields: [sizeId], references: [id])

  @@unique([orderItemId, sizeId])
  @@index([orderItemId])
  @@index([sizeId])
  @@map("order_item_sizes")
}

model OrderItemStage {
  id          String @id @default(uuid())
  orderItemId String
  stageId     String
  position    Int    @default(0)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  stage     Stage     @relation(fields: [stageId], references: [id])

  @@index([orderItemId])
  @@index([stageId])
  @@map("order_item_stages")
}
