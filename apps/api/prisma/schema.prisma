generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

model Company {
  id               String            @id @default(uuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  measurementUnits MeasurementUnit[]
  variables        Variable[]
  sectors          Sector[]
  stages           Stage[]
  templates        Template[]
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model MeasurementUnit {
  id        String   @id @default(uuid())
  companyId String
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  stages  Stage[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
}

model Variable {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  stages  Stage[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Sector {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  stages  Stage[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Stage {
  id                 String   @id @default(uuid())
  companyId          String
  sectorId           String
  measurementUnitId  String
  variableId         String?
  name               String
  description        String?
  capacityPerWorkday Decimal  @db.Decimal(12, 2)
  position           Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id])
  sector          Sector          @relation(fields: [sectorId], references: [id])
  measurementUnit MeasurementUnit @relation(fields: [measurementUnitId], references: [id])
  variable        Variable?       @relation(fields: [variableId], references: [id])
  templateItems   TemplateItem[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([sectorId])
  @@index([measurementUnitId])
  @@index([variableId])
}

model Template {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company        @relation(fields: [companyId], references: [id])
  items   TemplateItem[]

  @@unique([companyId, name])
  @@index([companyId])
}

model TemplateItem {
  id         String  @id @default(uuid())
  templateId String
  stageId    String
  position   Int     @default(0)

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  stage    Stage    @relation(fields: [stageId], references: [id])

  @@index([templateId])
  @@index([stageId])
}
