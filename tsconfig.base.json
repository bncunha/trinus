{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@trinus/shared": ["packages/shared/src/index.ts"],
      "@trinus/contracts": ["packages/contracts/src/index.ts"]
    }
  }
}

